# Copy to `.env` in this folder (and/or `apps/backend/.env`).
# Full explanations: CONFIGURATION.md

# --- Required for backend (set by docker-compose if omitted) ---
JWT_SECRET=change-me-use-long-random-in-production
JWT_EXPIRES_SECONDS=86400
DATABASE_URL=postgresql+psycopg2://waflow:waflow@db:5432/waflow
REDIS_URL=redis://redis:6379/0

# Local uvicorn on host: use 127.0.0.1 and run `docker compose up -d db redis`
# DATABASE_URL=postgresql+psycopg2://waflow:waflow@127.0.0.1:5432/waflow
# REDIS_URL=redis://127.0.0.1:6379/0

# --- Docker Compose ports ---
POSTGRES_DB=waflow
POSTGRES_USER=waflow
POSTGRES_PASSWORD=waflow
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=8000
FRONTEND_PORT=3000
REALTIME_PORT=4001

# Comma-separated browser origins allowed to call the API (and realtime Socket.IO).
# Production: https://app.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Legacy single origin for realtime (optional if CORS_ORIGINS is set)
CORS_ORIGIN=http://localhost:3000

# Frontend build-time (docker-compose.prod.yml): public API URL as seen by the browser
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Optional: pytest / dev ---
# TESTING=false
# AUTO_CREATE_TABLES=true

# --- Production (docker-compose.prod.yml) ---
# USE_GUNICORN=true and RUN_MIGRATIONS=true are set in docker-compose.prod.yml for the backend.
# RUN_MIGRATIONS runs `alembic upgrade head` before the API starts.
# WEB_CONCURRENCY=4
# GUNICORN_TIMEOUT=120

# --- Optional: seed one admin org on first startup ---
SEED_ADMIN=false
SEED_ADMIN_ORG_NAME=Demo Org
SEED_ADMIN_EMAIL=admin@demo.local
SEED_ADMIN_PASSWORD=admin12345

# --- WhatsApp Cloud API (Meta) — see CONFIGURATION.md ---
WHATSAPP_VERIFY_TOKEN=dev-verify-token
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v21.0
WHATSAPP_CONVERSATION_WINDOW_HOURS=24
MEDIA_UPLOAD_DIR=./data/media

# --- Email (SMTP) — optional; without SMTP_HOST, test email is logged only ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@example.com
